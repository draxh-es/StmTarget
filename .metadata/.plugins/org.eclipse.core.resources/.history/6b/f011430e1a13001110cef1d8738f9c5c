#include <stdio.h>
#include <stdint.h>

#include <stdint.h>

// Debug Exception and Monitor Control Register
#define DEMCR           (*(volatile uint32_t*)0xE000EDFCU)
#define TRCENA_BIT      (1UL << 24)

// ITM registers
#define ITM_TER         (*(volatile uint32_t*)0xE0000E00U) // Trace Enable Register
#define ITM_TCR         (*(volatile uint32_t*)0xE0000E80U) // Trace Control Register
#define ITM_STIM0_U8    (*(volatile uint8_t *)0xE0000000U) // Stimulus Port 0 (8-bit)

void ITM_SendChar(uint8_t ch)
{
    // Trace'i aç
    DEMCR |= TRCENA_BIT;

    // ITM enable + port 0 enable
    ITM_TCR |= 1UL;   // ITMENA
    ITM_TER |= 1UL;   // Stimulus port 0 enable

    // Direkt yaz (bekleme döngüsünü kaldırdık)
    ITM_STIM0_U8 = ch;
}


#if !defined(__SOFT_FP__) && defined(__ARM_FP)
#warning "FPU is not initialized, but the project is compiling for an FPU. Please initialize the FPU before use."
#endif

int main(void)
{
    for (volatile uint32_t i = 0; i < 2000000; i++);

    for (;;)
    {
        ITM_SendChar('.');
        for (volatile uint32_t d = 0; d < 2000000; d++);
    }
}
